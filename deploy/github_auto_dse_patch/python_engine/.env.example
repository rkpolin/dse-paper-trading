# Local development only. GitHub Actions should use GitHub Secrets instead.
# Never commit a real .env file.

CSV_PATH=python_engine/sample_data/dse_demo_prices.csv
DATA_SOURCE=auto
DSE_LATEST_URL=https://www.dsebd.org/latest_share_price_scroll_l.php
DSE_MARKET_STATUS_URL=https://www.dsebd.org/mst.txt
# Optional comma-separated watchlist. Leave blank to fetch all symbols from DSE.
DSE_SYMBOLS=
MERGE_DSE_WITH_CSV=true
INITIAL_BALANCE_BDT=100000
MAX_POSITION_PCT=0.10
MAX_OPEN_POSITIONS=5
TRANSACTION_COST_PCT=0.005
STOP_LOSS_PCT=-0.05
TAKE_PROFIT_PCT=0.08
EVALUATION_DAYS=5

# Hostinger API settings. Leave blank to generate a local JSON payload only.
HOSTINGER_API_BASE_URL=
HOSTINGER_API_TOKEN=
HOSTINGER_HMAC_SECRET=

# Optional Telegram notification after a run.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
