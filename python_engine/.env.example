# Local development only. GitHub Actions should use GitHub Secrets instead.
# Never commit a real .env file.

CSV_PATH=python_engine/sample_data/dse_demo_prices.csv
DATA_SOURCE=auto
DSE_LATEST_URL=https://www.dsebd.org/latest_share_price_scroll_l.php
DSE_MARKET_STATUS_URL=https://www.dsebd.org/mst.txt
DSE_ARCHIVE_URL=https://www.dsebd.org/day_end_archive.php
# DSE archive currently exposes a rolling public date window. 120 calendar days is enough for SMA50 context.
DSE_ARCHIVE_LOOKBACK_DAYS=120
# Optional comma-separated watchlist. Leave blank to fetch all symbols from DSE.
DSE_SYMBOLS=
MERGE_DSE_WITH_CSV=true
INITIAL_BALANCE_BDT=100000
MAX_POSITION_PCT=0.10
MAX_OPEN_POSITIONS=5
TRANSACTION_COST_PCT=0.005
STOP_LOSS_PCT=-0.05
TAKE_PROFIT_PCT=0.08
EVALUATION_DAYS=5

# Hostinger API settings. Leave blank to generate a local JSON payload only.
HOSTINGER_API_BASE_URL=
HOSTINGER_API_TOKEN=
HOSTINGER_HMAC_SECRET=
# Send a smaller recent payload to shared hosting while analysis still uses full data.
API_PAYLOAD_TRADING_DAYS=1
HOSTINGER_API_TIMEOUT_SECONDS=180

# Intraday time-pattern analyzer.
INTRADAY_HISTORY_CSV_PATH=python_engine/sample_data/dse_intraday_demo.csv
INTRADAY_BUCKET_TOLERANCE_MINUTES=8
INTRADAY_FORCE_RUN=false
INTRADAY_STAT_LOOKBACKS=20,30,60
# Optional comma-separated Bangladesh market holidays in YYYY-MM-DD format.
DSE_HOLIDAYS=

# Optional Telegram notification after a run.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
